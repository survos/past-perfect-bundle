{
    "name": "survos/past-perfect-bundle",
    "description": "Symfony bundle for harvesting PastPerfect Online collections",
    "keywords": [
        "pastperfect",
        "symfony",
        "harvest",
        "jsonl"
    ],
    "license": "MIT",
    "type": "symfony-bundle",
    "authors": [
        {
            "name": "Tac Tacelosky",
            "email": "tacman@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-dom": "*",
        "symfony/config": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/console": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/messenger": "^8.0",
        "survos/jsonl-bundle": "^2.0",
        "survos/site-discovery-bundle": "dev-main"
    },
    "require-dev": {
        "symfony/phpunit-bridge": "^8.0"
    },
    "suggest": {
        "survos/import-bundle": "Provides import:profile:report and import:convert for analysing harvested JSONL files"
    },
    "autoload": {
        "psr-4": {
            "Survos\\PastPerfectBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Survos\\PastPerfectBundle\\Tests\\": "tests/"
        }
    }
}
