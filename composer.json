{
    "name": "survos/past-perfect-bundle",
    "description": "Symfony bundle for harvesting PastPerfect Online collections",
    "keywords": [
        "pastperfect",
        "symfony",
        "harvest",
        "jsonl"
    ],
    "license": "MIT",
    "type": "symfony-bundle",
    "authors": [
        {
            "name": "Tac Tacelosky",
            "email": "tacman@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "symfony/config": "^7.3|^8.0",
        "symfony/dependency-injection": "^7.3|^8.0",
        "symfony/http-kernel": "^7.3|^8.0",
        "symfony/console": "^7.3|^8.0",
        "symfony/http-client": "^7.3|^8.0",
        "symfony/dom-crawler": "^7.3|^8.0",
        "symfony/css-selector": "^7.3|^8.0",
        "survos/jsonl-bundle": "^2.0"
    },
    "require-dev": {
        "symfony/phpunit-bridge": "^7.3|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Survos\\PastPerfectBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Survos\\PastPerfectBundle\\Tests\\": "tests/"
        }
    }
}
